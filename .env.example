# Google OAuth credentials for Account 1 (e.g., Business account)
GOOGLE_CLIENT_ID_1=your_client_id_here
GOOGLE_CLIENT_SECRET_1=your_client_secret_here

# Google OAuth credentials for Account 2 (e.g., Personal/Free account)
# You can use the same OAuth app for both, or create separate ones
GOOGLE_CLIENT_ID_2=your_client_id_here
GOOGLE_CLIENT_SECRET_2=your_client_secret_here

# Session secret (generate a random string)
SESSION_SECRET=your_session_secret_here

# Basic auth password (optional - leave empty to disable)
BASIC_AUTH_PASSWORD=your_password_here

# Server settings
PORT=3000
BASE_URL=http://localhost:3000

# Sync interval in minutes (default: 5)
SYNC_INTERVAL_MINUTES=5
